{
  "name": "@starchat/backend",
  "version": "0.1.0",
  "description": "StarChat Backend API",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "reset": "prisma migrate reset",
    "studio": "prisma studio",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@prisma/client": "^5.3.1",
    "@types/express": "^4.17.20",
    "@types/node": "^20.5.9",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.4",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.1.0",
    "minio": "^7.0.32",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.3",
    "redis": "^4.6.10",
    "socket.io": "^4.7.1",
    "socket.io-redis": "^6.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^8.50.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/bull": "^3.15.8",
    "@types/cors": "^2.8.14",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/node": "^20.5.9",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "@vitest/ui": "^0.34.6",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3",
    "prisma": "^5.3.1",
    "tsc-alias": "^1.8.8",
    "tsx": "^3.14.0",
    "typescript": "^5.2.2",
    "vitest": "^0.34.6"
  }
}
